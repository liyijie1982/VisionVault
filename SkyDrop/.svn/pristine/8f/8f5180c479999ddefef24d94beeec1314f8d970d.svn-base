func fileSizeKey(fileSize int64) string {
	if fileSize > 1024*1024*1024 {
		return "MORE1GB" //"1GB以上"
	} else if fileSize > 100*1024*1024 {
		return "MORE100MB" //"100MB以上"
	} else if fileSize > 1024*1024 {
		return "MORE1MB" //"1MB以上"
	} else {
		return "LESS1MB" //"1MB以内"
	}
}

func lastAccessTimeKey(lastAccessTime int64) string {
	if lastAccessTime < time.Now().Unix()-365*24*3600 {
		return "MORE1YEAR" //"一年以前"
	} else if lastAccessTime < time.Now().Unix()-182*24*3600 {
		return "HALF1YEAR" //"半年以前"
	} else if lastAccessTime < time.Now().Unix()-90*24*3600 {
		return "MORE3MONTH"
	} else {
		return "LESS3MONTH"
	}
}
